{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "renatalp",
  "compatibility_date": "2026-07-01",
  // Gera ./out antes de publicar — vale tanto localmente quanto no
  // Workers Builds (CI), mesmo sem "build command" configurado no painel.
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./out",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
